{
  "name": "@migrateiq/engine",
  "version": "1.0.0",
  "description": "MigrateIQ migration engine — SQL sources to Databricks and Microsoft Fabric",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "migrate": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "mssql": "^11.0.1",
    "pg": "^8.12.0",
    "mysql2": "^3.11.0",
    "axios": "^1.7.7",
    "yaml": "^2.5.1",
    "dotenv": "^16.4.5",
    "winston": "^3.14.2",
    "p-limit": "^6.1.0",
    "p-retry": "^6.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.1",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "@types/mssql": "^9.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
