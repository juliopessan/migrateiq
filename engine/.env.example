# === SOURCE CONNECTORS ===

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=mydb
PG_USER=postgres
PG_PASSWORD=secret

# SQL Server
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=mydb
MSSQL_USER=sa
MSSQL_PASSWORD=secret

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=mydb
MYSQL_USER=root
MYSQL_PASSWORD=secret

# === TARGET: DATABRICKS ===
DATABRICKS_HOST=https://adb-xxx.azuredatabricks.net
DATABRICKS_TOKEN=dapi_xxx
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=migrations
DATABRICKS_WAREHOUSE_ID=xxx
DATABRICKS_CLUSTER_ID=xxx

# === TARGET: MICROSOFT FABRIC ===
FABRIC_TENANT_ID=xxx
FABRIC_CLIENT_ID=xxx
FABRIC_CLIENT_SECRET=xxx
FABRIC_WORKSPACE_ID=xxx
FABRIC_LAKEHOUSE_ID=xxx
FABRIC_SERVER=xxx.datawarehouse.fabric.microsoft.com
FABRIC_DATABASE=xxx

# === MIGRATION SETTINGS ===
MIGRATION_BATCH_SIZE=10000
MIGRATION_MAX_RETRIES=3
MIGRATION_CHECKPOINT_INTERVAL=50000
LOG_LEVEL=info
